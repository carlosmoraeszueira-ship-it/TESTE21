          {CONS.map(c => <div key={c.id}>{c.email}</div>)}
        </div>
      </div>
    </div>
  );
}

/* ── APP PRINCIPAL ───────────────────────────── */
export default function App() {
  const [user,     setUser]     = useState(null);
  const [view,     setView]     = useState("dashboard");
  const [selId,    setSelId]    = useState(null);
  const [clis,     setClis]     = useState(CLIS0);
  const [presMode, setPresMode] = useState(null);
  const [loading,  setLoading]  = useState(false);
  const [saveStatus, showSave]  = useSaveStatus();

  const meus = useMemo(() => user ? clis.filter(c => c.cId === user.id) : [], [clis, user]);
  const sel  = useMemo(() => clis.find(c => c.id === selId), [clis, selId]);

  async function handleLogin(u) {
    setLoading(true);
    const saved = await loadData(u.id);
    if (saved) {
      const defaults  = CLIS0.filter(c => c.cId === u.id);
      const merged    = defaults.map(d => saved.find(s => s.id===d.id) || d);
      const extras    = saved.filter(s => !defaults.some(d => d.id===s.id));
      setClis(prev => [...prev.filter(c => c.cId !== u.id), ...merged, ...extras]);
    }
    setUser(u);
    setLoading(false);
  }

  useEffect(() => {
    if (!user) return;
    const t = setTimeout(async () => {
      showSave("saving");
      await saveData(user.id, meus);
      showSave("ok");
    }, 800);
    return () => clearTimeout(t);
  }, [meus, user]);

  function updCli(upd) { setClis(p => p.map(c => c.id===upd.id ? upd : c)); }
  function addCli(novo) { setClis(p => [...p, novo]); setView("clientes"); }
  function navTo(v) { setView(v); setSelId(null); }

  if (!user) return <Login onLogin={handleLogin}/>;
  if (loading) return (
    <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:"var(--color-background-secondary)"}}>
      <div style={{...s0,fontSize:13}}>Carregando dados salvos...</div>
    </div>
  );
  if (presMode) return <ModoApresentacao cli={presMode} consultor={user.nome} onSair={() => setPresMode(null)}/>;

  return (
    <div style={{display:"flex",minHeight:"100vh",background:"var(--color-background-secondary)"}}>
      <Sidebar user={user} view={view} setView={navTo} saveStatus={saveStatus} onLogout={() => { setUser(null); navTo("dashboard"); }}/>
      <div style={{flex:1,display:"flex",flexDirection:"column",overflowX:"hidden"}}>
        {view === "dashboard"       && <Dashboard    clientes={meus} onSel={id => { setSelId(id); setView("cliente_detail"); }}/>}
        {view === "clientes"        && <ClientesList clientes={meus} onSel={id => { setSelId(id); setView("cliente_detail"); }} onNovo={() => setView("novo_cliente")}/>}
        {view === "cliente_detail"  && sel && <ClienteDetail cli={sel} onBack={() => setView("clientes")} onUpd={updCli} onPresMode={cli => {
          const snap = criarSnapshot({ lans:cli.lans||[], pjData:cli.pjData||{}, consultor:user.nome, tipo:"apresentacao", nota:"" });
          const atualizado = { ...cli, ultApres:TODAY, status:"apresentado", _consultor:user.nome, snapshots:[snap,...(cli.snapshots||[])] };
          updCli(atualizado);
          setPresMode(atualizado);
        }}/> }
        {view === "novo_cliente"    && <NovoCliente cId={user.id} onSalvar={addCli} onCancel={() => setView("clientes")}/>}
        {view === "inteligencia"    && (
          <div style={{padding:"24px 28px",flex:1,overflowY:"auto"}}>
            <div style={{fontSize:17,fontWeight:500,marginBottom:2}}>Inteligência da carteira</div>
            <div style={{...s0,fontSize:12,marginBottom:18}}>Ranking de risco fiscal · análise cross-cliente · impacto estimado</div>
            <IntelCarteira clientes={meus}/>
          </div>
        )}
      </div>
    </div>
  );
}
