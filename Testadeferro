}

/* ── LOGIN ───────────────────────────────────── */
function Login({ onLogin }) {
  const [em, setEm] = useState("");
  const [pw, setPw] = useState("");
  const [err, setErr] = useState("");
  function go() {
    const u = CONS.find(c => c.email === em && c.senha === pw);
    u ? onLogin(u) : setErr("E-mail ou senha incorretos.");
  }
  return (
    <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:"var(--color-background-secondary)"}}>
      <div style={{background:"var(--color-background-primary)",border:"0.5px solid var(--color-border-tertiary)",borderRadius:16,padding:"36px 40px",width:"100%",maxWidth:380}}>
        <div style={{fontSize:18,fontWeight:500,marginBottom:4}}>Espelho Fiscal 2026</div>
        <div style={{...s0,fontSize:12,marginBottom:24}}>Lei 15.270/2025 · Acesso restrito a consultores</div>
        <div style={{marginBottom:14}}>
          <label style={{...s0,fontSize:12,display:"block",marginBottom:5}}>E-mail</label>
          <input type="text" value={em} onChange={e=>setEm(e.target.value)} placeholder="consultor@firma.com" style={{...i0,width:"100%"}} onKeyDown={e=>e.key==="Enter"&&go()}/>
        </div>
        <div style={{marginBottom:14}}>
          <label style={{...s0,fontSize:12,display:"block",marginBottom:5}}>Senha</label>
          <input type="password" value={pw} onChange={e=>setPw(e.target.value)} placeholder="••••••" style={{...i0,width:"100%"}} onKeyDown={e=>e.key==="Enter"&&go()}/>
        </div>
        {err && <div style={{fontSize:12,color:"var(--color-text-danger)",marginBottom:12}}>{err}</div>}
        <button onClick={go} style={{width:"100%",padding:"9px",borderRadius:8,fontSize:13,fontWeight:500,background:"var(--color-background-info)",color:"var(--color-text-info)",border:"0.5px solid var(--color-border-info)",cursor:"pointer"}}>Entrar</button>
