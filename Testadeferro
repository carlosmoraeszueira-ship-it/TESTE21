    onSalvar({ id:"cli_"+Date.now(), cId, nome:f.nome, cpf:f.cpf||"***.***.***-00", status:"novo", rend:parseFloat(f.rend)||0, ultApres:null, proxFup:null, notaFup:"", pend:0, hist:[], notas:f.notas, cadastro:TODAY, lans:[], cens:[], pjData:{} });
