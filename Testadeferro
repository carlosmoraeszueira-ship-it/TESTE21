/* ── MOTOR ──────────────────────────────────── */
function calcMotor6A(lans) {
  const ac = {}, res = {};
  [...lans]
    .filter(l => TAX[l.cod]?.i6A && !l.grandfathering)
    .sort((a, b) => a.data === b.data ? (a.seq||0)-(b.seq||0) : a.data.localeCompare(b.data))
    .forEach(ev => {
      const mes = ev.data.slice(0,7), k = `${ev.cnpj}__${mes}`;
      if (!ac[k]) ac[k] = { tot:0, iAc:0 };
      ac[k].tot += ev.valorBruto;
      const sup = ac[k].tot > TRC.a6.lim;
      const iT = sup ? ac[k].tot * TRC.a6.aliq : 0;
      const iEv = Math.max(0, iT - ac[k].iAc);
      ac[k].iAc = iT;
      res[ev.id] = { dep: ac[k].tot, mes, cnpj: ev.cnpj, nome: ev.nome, sup, iT, iEv };
    });
  return res;
}

function calcBase(lans) {
  const evs = [], excl = [], pend = [];
  let bB = 0;
  lans.forEach(l => {
    const t = TAX[l.cod];
    if (!t) { pend.push({ id:l.id, nome:l.nome||l.cod, m:"Não classificado" }); return; }
    if (!t.eR) return;
    bB += l.valorBruto;
    if (l.grandfathering) { excl.push({ id:l.id, v:l.valorBruto, m:"Grandfathering", cod:l.cod }); return; }
    if (t.c) {
      if (l.requisitosIsencao === true) excl.push({ id:l.id, v:l.valorBruto, m:"FII/Fiagro isento", cod:l.cod });
      else { pend.push({ id:l.id, nome:l.nome, m:"Requisitos FII/Fiagro não confirmados" }); evs.push({...l}); }
      return;
    }
    t.bM ? evs.push({...l}) : excl.push({ id:l.id, v:l.valorBruto, m:"Exclusão legal", cod:l.cod });
  });
  return { bM: evs.reduce((s,e) => s + e.valorBruto, 0), bB, excl, pend };
}

function calcAliq(b) {
  if (b <= TRC.a16.lz) return 0;
  if (b >= TRC.a16.lf) return TRC.a16.af;
  return (b / TRC.a16.div - TRC.a16.k) / 100;
}

function calcRedutores(lans, bM, tMB, pjData) {
  const divPJ = {};
  lans.forEach(l => {
    if ((l.cod !== "DIV_FECHADA" && l.cod !== "DIV_ABERTA") || l.grandfathering || !TAX[l.cod]?.bM) return;
    if (!divPJ[l.cnpj]) divPJ[l.cnpj] = { nome: l.nome, total: 0 };
    divPJ[l.cnpj].total += l.valorBruto;
  });
  return Object.entries(divPJ).map(([cnpj, { nome, total }]) => {
    const pd = (pjData||{})[cnpj] || {};
    const { irpjCsll, lucroContabil, tipoPJ = "geral" } = pd;
    const pend = irpjCsll == null || lucroContabil == null || lucroContabil === 0;
    const lim = TRC.a16b.limites[tipoPJ] || 0.34;
    const bMSem = Math.max(0, bM - total);
    const tSem = bMSem * calcAliq(bMSem);
    const ac = Math.max(0, tMB - tSem);
    const aPF = total > 0 ? ac / total : 0;
    const aPJ = (!pend && lucroContabil > 0) ? irpjCsll / lucroContabil : null;
    const soma = !pend ? aPJ + aPF : null;
    const exc = !pend && soma > lim;
    const dif = exc ? soma - lim : 0;
    const red = exc ? total * dif : 0;
    return { cnpj, nome, dividendos: total, tCom: tMB, tSem, ac, aPF, aPJ, soma, lim, exc, dif, red, pend, tipoPJ, pd };
  });
}

function calcTrib(lans, m6A, pjData) {
  const { bM, bB, excl, pend } = calcBase(lans);
  const aliq = calcAliq(bM), tMB = bM * aliq;
  const incI   = lans.reduce((s,l) => TAX[l.cod]?.inc === "incI"  ? s + l.irrf : s, 0);
  const incII  = lans.reduce((s,l) => TAX[l.cod]?.inc === "incII" && TAX[l.cod]?.bM ? s + l.irrf : s, 0);
  const incIII = lans.reduce((s,l) => TAX[l.cod]?.inc === "incIII" ? s + l.irrf : s, 0);
  const reds   = calcRedutores(lans, bM, tMB, pjData || {});
  const incV   = reds.reduce((s,r) => s + r.red, 0);
  const tD3 = incI + incII + incIII + incV;
  const r3 = tMB - tD3, r4 = Math.max(0, r3), p4 = r3 < 0;
  const i6A = Object.values(m6A).reduce((s,m) => s + m.iEv, 0);
  const r5 = r4 - i6A;
  const cL = lans.filter(l => l.cod === "CARNE_LEAO").reduce((s,l) => s + l.irrf, 0);
  const iP = lans.reduce((s,l) => TAX[l.cod]?.inc === "incI" ? s + l.irrf : s, 0);
  const sDF = -(iP + cL) + r5;
  return { bB, bM, excl, pend, aliq, tMB, incI, incII, incIII, incV, reds, tD3, r3, r4, p4, i6A, r5, cL, iP, sDA: -(iP+cL), sDF };
}

function fullCalc(lans, pjData) {
  const m = calcMotor6A(lans);
  return calcTrib(lans, m, pjData);
}

/* ── DADOS MENSAIS ───────────────────────────── */
const MESES_PT = ["Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"];

function buildMonthlyData(lans) {
  const months = {};
  for (let m = 1; m <= 12; m++) {
    const k = `2026-${String(m).padStart(2,"0")}`;
    months[k] = { baseMin:0, irrf6A:0, mes:m };
  }
  const m6A = calcMotor6A(lans);
  lans.forEach(l => {
    const t = TAX[l.cod];
    if (!t || !t.eR || !t.bM || l.grandfathering) return;
    const mes = l.data.slice(0,7);
    if (months[mes]) months[mes].baseMin += l.valorBruto;
  });
  Object.values(m6A).forEach(m => {
    if (months[m.mes]) months[m.mes].irrf6A += m.iEv;
  });
  let cum = 0;
  return Object.entries(months).sort().map(([k,d]) => {
    cum += d.baseMin;
    return { ...d, k, cumBase: cum, label: MESES_PT[d.mes - 1] };
  });
}

