/* ── PERSISTÊNCIA ────────────────────────────── */
const SKEY = cId => `espelho:v1:${cId}`;

async function saveData(cId, clis) {
  try { await window.storage.set(SKEY(cId), JSON.stringify(clis)); } catch(e) { console.error(e); }
}
async function loadData(cId) {
  try { const r = await window.storage.get(SKEY(cId)); if (r) return JSON.parse(r.value); } catch(e) {}
  return null;
}

function useSaveStatus() {
  const [status, setStatus] = useState(null);
  const show = useCallback(s => { setStatus(s); setTimeout(() => setStatus(null), 2200); }, []);
  return [status, show];
}

