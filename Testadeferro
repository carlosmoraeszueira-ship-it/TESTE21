              <label style={{...s0,fontSize:11}}>{row.l}</label>
              {row.el}
            </div>
          ))}
          <button onClick={add} style={{padding:"6px 16px",borderRadius:8,fontSize:13,background:"var(--color-background-info)",color:"var(--color-text-info)",border:"0.5px solid var(--color-border-info)",cursor:"pointer",fontWeight:500,marginTop:14}}>+ Adicionar</button>
        </div>
      </div>
      {lans.length > 0 && (
        <div style={C}>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
              <thead>
                <tr style={{borderBottom:"0.5px solid var(--color-border-tertiary)"}}>
                  {["Tipo","Grupo","Data","Fonte","Valor","IRRF","Base mín.",""].map(h => (
                    <th key={h} style={{textAlign:"left",padding:"5px 8px",fontWeight:500,...s0,fontSize:11,whiteSpace:"nowrap"}}>{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {lans.map(l => {
                  const t = TAX[l.cod];
                  const CORG = {Dividendos:"#185FA5","Renda Fixa":"#0F6E56",Isento:"#639922",Especial:"#BA7517",Trabalho:"#534AB7",Ajuste:"#888780",Crédito:"#888780"};
                  return (
                    <tr key={l.id} style={{borderBottom:"0.5px solid var(--color-border-tertiary)"}}>
                      <td style={{padding:"5px 8px"}}>{t?.n || <span style={{color:"var(--color-text-danger)"}}>! {l.cod}</span>}</td>
                      <td style={{padding:"5px 8px"}}>{t ? <span style={{fontSize:11,padding:"2px 7px",borderRadius:99,background:(CORG[t.g]||"#888")+"22",color:CORG[t.g]||"#888",fontWeight:500}}>{t.g}</span> : "?"}</td>
                      <td style={{padding:"5px 8px",whiteSpace:"nowrap"}}>{l.data}</td>
                      <td style={{padding:"5px 8px",maxWidth:130,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{l.nome}</td>
                      <td style={{padding:"5px 8px",textAlign:"right",whiteSpace:"nowrap"}}>{fmt(l.valorBruto)}</td>
                      <td style={{padding:"5px 8px",textAlign:"right",whiteSpace:"nowrap"}}>{l.irrf>0?fmt(l.irrf):<span style={{color:"var(--color-text-tertiary)"}}>—</span>}</td>
                      <td style={{padding:"5px 8px",textAlign:"center",fontSize:11,color:t?.bM?"var(--color-text-success)":"var(--color-text-tertiary)"}}>{t?.bM?"Sim":"Não"}</td>
                      <td style={{padding:"5px 8px"}}><button onClick={() => onUpdate(lans.filter(x => x.id !== l.id))} style={{background:"none",border:"none",cursor:"pointer",color:"var(--color-text-danger)",fontSize:13,padding:0}}>✕</button></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}

/* ── ESPELHO FISCAL ──────────────────────────── */
function EspelhoFiscal({ lans, onUpdate, pjData, onUpdatePjData, clienteNome }) {
  const [sub, setSub] = useState("resumo");
  const [editCnpj, setEditCnpj] = useState(null);
  const [ef, setEf] = useState({ irpjCsll:"", lucroContabil:"", tipoPJ:"geral" });
  const m6A  = useMemo(() => calcMotor6A(lans), [lans]);
  const trib = useMemo(() => calcTrib(lans, m6A, pjData), [lans, m6A, pjData]);
  const pct  = Math.min(100, (trib.bM / TRC.a16.lf) * 100);

  function startEdit(r) { setEditCnpj(r.cnpj); setEf({ irpjCsll:r.pd.irpjCsll??'', lucroContabil:r.pd.lucroContabil??'', tipoPJ:r.pd.tipoPJ||"geral" }); }
  function salvarPJ(cnpj) { onUpdatePjData({...pjData,[cnpj]:{irpjCsll:ef.irpjCsll!==''?parseFloat(ef.irpjCsll):null,lucroContabil:ef.lucroContabil!==''?parseFloat(ef.lucroContabil):null,tipoPJ:ef.tipoPJ}}); setEditCnpj(null); }

  const tabs = [
    { id:"resumo",     l:"Resumo" },
    { id:"grafico",    l:"Evolução mensal" },
    { id:"lancamentos",l:"Lançamentos" },
    { id:"fluxo",      l:"Fluxo §§ 3–6" },
    { id:"redutor",    l:`Redutor 16-B${trib.incV>0?" ✓":trib.reds?.some(r=>r.pend)?" ⚠":""}` },
  ];

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
        <div style={{fontSize:12,fontWeight:500}}>Espelho fiscal — {clienteNome}</div>
        <span style={{fontSize:11,fontFamily:"monospace",color:"var(--color-text-tertiary)",background:"var(--color-background-secondary)",padding:"2px 8px",borderRadius:6}}>{TRC.v} · {TRC.norm}</span>
      </div>
      <div style={{...s0,fontSize:12,marginBottom:12}}>Cenário projetado · impacto fiscal estimado · pendências que podem alterar o resultado</div>
      <div style={{display:"flex",gap:6,marginBottom:14,flexWrap:"wrap"}}>
        {tabs.map(t => (
          <button key={t.id} onClick={() => setSub(t.id)} style={{padding:"5px 13px",borderRadius:8,fontSize:12,cursor:"pointer",background:sub===t.id?"var(--color-background-info)":"transparent",color:sub===t.id?"var(--color-text-info)":"var(--color-text-secondary)",border:`0.5px solid ${sub===t.id?"var(--color-border-info)":"var(--color-border-tertiary)"}`,fontWeight:sub===t.id?500:400}}>{t.l}</button>
        ))}
      </div>

      {sub === "resumo" && (
        <div>
          <div style={{display:"flex",gap:10,flexWrap:"wrap",marginBottom:12}}>
            <MetricCard label="Rendimentos brutos"  value={fmt(trib.bB)}/>
            <MetricCard label="Base trib. mínima"   value={fmt(trib.bM)}/>
            <MetricCard label="Trib. mínima bruta"  value={fmt(trib.tMB)}/>
            <MetricCard label="Redutor 16-B"         value={fmt(trib.incV)} ok={trib.incV>0}/>
            <MetricCard label="Resultado § 5º"       value={fmt(trib.r5)}   danger={trib.r5>0} ok={trib.r5<0}/>
            <MetricCard label="Saldo DAA est."        value={fmt(trib.sDF)}  danger={trib.sDF>0} ok={trib.sDF<0}/>
          </div>
          <div style={C}>
            <div style={{...s0,fontSize:11,marginBottom:6}}>Termômetro da base mínima</div>
            <div style={{display:"flex",alignItems:"center",gap:10}}>
              <div style={{flex:1,height:8,borderRadius:99,background:"var(--color-background-secondary)",overflow:"hidden"}}>
                <div style={{height:"100%",borderRadius:99,width:`${pct}%`,background:trib.bM>=TRC.a16.lf?"#E24B4A":trib.bM>TRC.a16.lz?"#EF9F27":"#1D9E75",transition:"width .4s"}}/>
              </div>
              <span style={{fontSize:13,fontWeight:500,minWidth:44}}>{fmtP(trib.aliq)}</span>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",...s0,fontSize:10,marginTop:3}}><span>R$0</span><span>R$600k</span><span>R$1,2M</span></div>
          </div>
          {trib.pend.length > 0 && (
            <div style={{...C,borderColor:"var(--color-border-warning)",background:"var(--color-background-warning)"}}>
              <div style={{fontSize:12,fontWeight:500,color:"var(--color-text-warning)",marginBottom:6}}>Pendências ({trib.pend.length})</div>
              {trib.pend.map((p,i) => <div key={i} style={{fontSize:12,color:"var(--color-text-warning)",marginBottom:2}}>· {p.nome}: {p.m}</div>)}
            </div>
          )}
          {lans.length === 0 && (
            <div style={{...C,textAlign:"center",padding:24,background:"var(--color-background-secondary)"}}>
              <div style={{...s0,marginBottom:8}}>Nenhum lançamento cadastrado.</div>
              <button onClick={() => setSub("lancamentos")} style={{fontSize:12,padding:"5px 14px",borderRadius:8,background:"var(--color-background-info)",color:"var(--color-text-info)",border:"0.5px solid var(--color-border-info)",cursor:"pointer"}}>Adicionar primeiro lançamento</button>
            </div>
          )}
        </div>
      )}

      {sub === "grafico"     && <GraficoMensal lans={lans}/>}
      {sub === "lancamentos" && <LanEditor lans={lans} onUpdate={onUpdate}/>}

      {sub === "fluxo" && (
        <div>
          <div style={C}>
            <RowLine l="Base bruta de rendimentos" v={fmt(trib.bB)}/>
            {trib.excl.map((e,i) => <RowLine key={i} l={`(-) ${e.m}`} v={`- ${fmt(e.v)}`} ind/>)}
            <RowLine l={`= Base da tributação mínima — ${trib.excl.length} exclusão(ões)`} v={fmt(trib.bM)} bold/>
            <RowLine l={`Alíquota — ${trib.bM>=TRC.a16.lf?"flat 10%":trib.bM<=TRC.a16.lz?"0%":"linear"}`} v={fmtP(trib.aliq)}/>
            <RowLine l="= Tributação mínima bruta (§ 2º)" v={fmt(trib.tMB)} bold/>
          </div>
          <div style={C}>
            <div style={{...s0,fontSize:11,marginBottom:4}}>Deduções § 3º</div>
            <RowLine l="Inc. I — IRRF progressivo retido (estimado)*" v={`- ${fmt(trib.incI)}`} ind/>
            <RowLine l="Inc. II — IRRF exclusivo/definitivo na base" v={`- ${fmt(trib.incII)}`} ind/>
            <RowLine l="Inc. III — IR Lei 14.754/2023" v={`- ${fmt(trib.incIII)}`} ind/>
            <RowLine l={`Inc. V — Redutor Art. 16-B${trib.incV>0?" (aplicado)":trib.reds?.some(r=>r.pend)?" (⚠ pendente)":" (não aplicável)"}`} v={`- ${fmt(trib.incV)}`} ind ok={trib.incV>0}/>
            <RowLine l={`§ 4º — ${trib.p4?"negativo → zero (continua ao § 5º)":"positivo, sem alteração"}`} v={fmt(trib.r4)} bold/>
          </div>
          <div style={C}>
            <RowLine l="§ 5º — (-) IRRF antecipado Art. 6º-A" v={`- ${fmt(trib.i6A)}`} ind/>
            <RowLine l="= Resultado § 5º" v={fmt(trib.r5)} bold ok={trib.r5<0} dg={trib.r5>0}/>
            <RowLine l="§ 6º — Saldo DAA final estimado" v={fmt(trib.sDF)} bold ok={trib.sDF<0} dg={trib.sDF>0}/>
            <div style={{fontSize:11,color:"var(--color-text-tertiary)",marginTop:8}}>* Inc. I correto = IRPF DEVIDO na tabela progressiva anual. Diferença estimada pode variar.</div>
          </div>
        </div>
      )}

      {sub === "redutor" && (
        <div>
          {!(trib.reds?.length) ? (
            <div style={{...C,textAlign:"center",padding:28,...s0}}>Adicione DIV_FECHADA ou DIV_ABERTA para habilitar o Redutor Art. 16-B.</div>
          ) : trib.reds.map(r => (
            <div key={r.cnpj} style={{...C,borderLeft:`3px solid ${r.pend?"var(--color-border-warning)":r.red>0?"#1D9E75":"var(--color-border-tertiary)"}`,borderRadius:"0 12px 12px 0"}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:10}}>
                <div>
                  <div style={{fontSize:14,fontWeight:500}}>{r.nome}</div>
                  <div style={{...s0,fontSize:11,marginTop:2}}>CNPJ: {r.cnpj} · Dividendos: {fmt(r.dividendos)}</div>
                </div>
                <div style={{display:"flex",gap:6}}>
                  <span style={{fontSize:11,padding:"2px 10px",borderRadius:99,background:r.pend?"var(--color-background-warning)":r.red>0?"var(--color-background-success)":"var(--color-background-secondary)",color:r.pend?"var(--color-text-warning)":r.red>0?"var(--color-text-success)":"var(--color-text-secondary)",fontWeight:500}}>{r.pend?"Pendente":r.red>0?"Redutor aplicado":"Sem excesso"}</span>
                  <button onClick={() => editCnpj===r.cnpj ? setEditCnpj(null) : startEdit(r)} style={{fontSize:11,padding:"3px 10px",borderRadius:6,border:"0.5px solid var(--color-border-secondary)",background:"transparent",...s0,cursor:"pointer"}}>{editCnpj===r.cnpj?"Cancelar":"Editar PJ"}</button>
                </div>
              </div>
              {editCnpj === r.cnpj && (
                <div style={{background:"var(--color-background-secondary)",borderRadius:10,padding:14,marginBottom:12}}>
                  <div style={{display:"flex",gap:10,flexWrap:"wrap",marginBottom:10}}>
                    {[{l:"IRPJ + CSLL (R$)",k:"irpjCsll"},{l:"Lucro contábil (R$)",k:"lucroContabil"}].map(fld => (
                      <div key={fld.k} style={{display:"flex",flexDirection:"column",gap:4,flex:1,minWidth:150}}>
                        <label style={{...s0,fontSize:11}}>{fld.l}</label>
                        <input type="number" value={ef[fld.k]} onChange={e=>setEf(p=>({...p,[fld.k]:e.target.value}))} style={{...i0,width:"100%"}}/>
                      </div>
                    ))}
                    <div style={{display:"flex",flexDirection:"column",gap:4}}>
                      <label style={{...s0,fontSize:11}}>Tipo da PJ</label>
                      <select value={ef.tipoPJ} onChange={e=>setEf(p=>({...p,tipoPJ:e.target.value}))} style={i0}>
                        {Object.entries(TRC.a16b.tipoLabels).map(([k,v]) => <option key={k} value={k}>{v}</option>)}
                      </select>
                    </div>
                  </div>
                  <button onClick={() => salvarPJ(r.cnpj)} style={{padding:"6px 14px",borderRadius:8,fontSize:12,fontWeight:500,background:"var(--color-background-info)",color:"var(--color-text-info)",border:"0.5px solid var(--color-border-info)",cursor:"pointer"}}>Salvar</button>
                </div>
              )}
              {!r.pend && (
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(130px,1fr))",gap:8}}>
                  {[{l:"Alíq. efetiva PJ",v:fmtP(r.aPJ)},{l:"Alíq. efetiva PF",v:fmtP(r.aPF)},{l:"Soma alíquotas",v:fmtP(r.soma)},{l:`Limite (${TRC.a16b.tipoLabels[r.tipoPJ]})`,v:fmtP(r.lim)},{l:"Redutor (Inc. V)",v:fmt(r.red),ok:r.red>0}].map(m => (
                    <div key={m.l} style={{background:"var(--color-background-secondary)",borderRadius:8,padding:"8px 12px"}}>
                      <div style={{...s0,fontSize:10,marginBottom:2}}>{m.l}</div>
                      <div style={{fontSize:13,fontWeight:500,color:m.ok?"var(--color-text-success)":"var(--color-text-primary)"}}>{m.v}</div>
                    </div>
                  ))}
                </div>
              )}
              {r.pend && <div style={{padding:"10px 14px",background:"var(--color-background-warning)",borderRadius:8,fontSize:12,color:"var(--color-text-warning)"}}>Informe IRPJ+CSLL e Lucro Contábil da PJ. Art. 16-B § 4º: exige demonstrações financeiras.</div>}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

/* ── SIMULADOR ───────────────────────────────── */
function Simulador({ baseLans, cens, onUpdateCens, clienteNome, pjData }) {
  const [modo, setModo]     = useState("list");
  const [selCen, setSelCen] = useState(null);
  const [bNome, setBNome]   = useState("");
  const [bDesc, setBDesc]   = useState("");
  const [bLans, setBLans]   = useState([]);
  const [editId, setEditId] = useState(null);
  const bT = useMemo(() => fullCalc(baseLans, pjData), [baseLans, pjData]);

  function openBuilder(cen=null) {
    setEditId(cen ? cen.id : null);
    setBNome(cen ? cen.nome : "");
    setBDesc(cen ? cen.desc : "");
    setBLans(cen ? [...cen.lans] : baseLans.map(l => ({...l, id:"c_"+l.id})));
    setModo("builder");
  }
  function salvar() {
    if (!bNome) return;
    const novo = { id: editId || "s_"+Date.now(), nome: bNome, desc: bDesc, criadoEm: TODAY, lans: bLans };
    onUpdateCens(editId ? cens.map(c => c.id===editId ? novo : c) : [...cens, novo]);
    setModo("list");
  }

  if (modo === "builder") {
    return (
      <div>
        <button onClick={() => setModo("list")} style={{...s0,fontSize:12,border:"none",background:"none",cursor:"pointer",marginBottom:14,padding:0}}>← Cancelar</button>
        <div style={{fontSize:14,fontWeight:500,marginBottom:14}}>{editId?"Editar":"Novo"} cenário</div>
        <div style={C}>
          <div style={{display:"flex",gap:10,flexWrap:"wrap",marginBottom:12}}>
            <div style={{display:"flex",flexDirection:"column",gap:4,flex:1}}>
              <label style={{...s0,fontSize:11}}>Nome *</label>
              <input value={bNome} onChange={e=>setBNome(e.target.value)} style={{...i0,width:"100%"}} placeholder="Ex.: Cenário A"/>
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:4,flex:2}}>
              <label style={{...s0,fontSize:11}}>Descrição / premissas</label>
              <input value={bDesc} onChange={e=>setBDesc(e.target.value)} style={{...i0,width:"100%"}} placeholder="Premissas consideradas..."/>
            </div>
          </div>
          <button onClick={salvar} disabled={!bNome} style={{padding:"7px 18px",borderRadius:8,fontSize:13,fontWeight:500,background:bNome?"var(--color-background-info)":"var(--color-background-secondary)",color:bNome?"var(--color-text-info)":"var(--color-text-tertiary)",border:`0.5px solid ${bNome?"var(--color-border-info)":"var(--color-border-tertiary)"}`,cursor:bNome?"pointer":"default"}}>{editId?"Salvar alterações":"Salvar cenário"}</button>
        </div>
        <LanEditor lans={bLans} onUpdate={setBLans}/>
      </div>
    );
  }

  if (modo === "compare" && selCen) {
    const cT = fullCalc(selCen.lans, pjData);
    const rows = [
      {l:"Rendimentos brutos", bv:bT.bB,   cv:cT.bB},
      {l:"Base trib. mínima",  bv:bT.bM,   cv:cT.bM},
      {l:"Alíquota",           bv:bT.aliq, cv:cT.aliq, pct:true, lB:true},
      {l:"Trib. mínima bruta", bv:bT.tMB,  cv:cT.tMB,  lB:true},
      {l:"Redutor 16-B",       bv:bT.incV, cv:cT.incV, lB:true},
      {l:"IRRF Art. 6º-A",     bv:bT.i6A,  cv:cT.i6A,  lB:true, dest:true},
      {l:"Saldo DAA estimado",  bv:bT.sDF,  cv:cT.sDF,  lB:true, dest:true},
    ];
    function dif(bv, cv, pct, lB) {
      const d = cv - bv;
      if (Math.abs(d) < 0.01) return { txt:"—", cor:"var(--color-text-tertiary)" };
      return { txt: pct ? (d>=0?"+":"")+((d)*100).toFixed(2)+"p.p." : (d>=0?"+":"")+fmt(cv-bv), cor: lB?(d<0?"var(--color-text-success)":"var(--color-text-danger)"):"var(--color-text-primary)" };
    }
    return (
      <div>
        <button onClick={() => setModo("list")} style={{...s0,fontSize:12,border:"none",background:"none",cursor:"pointer",marginBottom:14,padding:0}}>← Voltar</button>
        <div style={{fontSize:14,fontWeight:500,marginBottom:12}}>Cenário Base × {selCen.nome}</div>
        <div style={{...C,overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
            <thead>
              <tr style={{borderBottom:"0.5px solid var(--color-border-tertiary)"}}>
                {["Métrica","Base","Cenário","Diferença est."].map((h,i) => <th key={i} style={{textAlign:i===0?"left":"right",padding:"8px 12px",fontWeight:500,...s0,fontSize:11}}>{h}</th>)}
              </tr>
            </thead>
            <tbody>
              {rows.map((r,i) => {
                const d = dif(r.bv, r.cv, r.pct, r.lB);
                return (
                  <tr key={i} style={{borderBottom:"0.5px solid var(--color-border-tertiary)",background:r.dest?"var(--color-background-secondary)":"transparent"}}>
                    <td style={{padding:"8px 12px",fontWeight:r.dest?500:400}}>{r.l}</td>
                    <td style={{padding:"8px 12px",textAlign:"right",fontFamily:"monospace"}}>{r.pct?fmtP(r.bv):fmt(r.bv)}</td>
                    <td style={{padding:"8px 12px",textAlign:"right",fontFamily:"monospace"}}>{r.pct?fmtP(r.cv):fmt(r.cv)}</td>
                    <td style={{padding:"8px 12px",textAlign:"right",fontWeight:500,color:d.cor,fontFamily:"monospace"}}>{d.txt}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        {bT.bM === cT.bM && <div style={{...C,background:"var(--color-background-info)",borderColor:"var(--color-border-info)"}}><div style={{fontSize:12,fontWeight:500,color:"var(--color-text-info)",marginBottom:4}}>Carga anual estimada idêntica</div><div style={{fontSize:12,color:"var(--color-text-info)"}}>Base mínima igual — diferença de IRRF Art. 6-A é apenas de fluxo de caixa, sem benefício fiscal anual real.</div></div>}
        <div style={{...C,borderColor:"var(--color-border-danger)",background:"var(--color-background-danger)"}}><div style={{fontSize:12,color:"var(--color-text-danger)"}}>Diferença estimada · não constitui recomendação de investimento · pendências podem alterar o resultado.</div></div>
      </div>
    );
  }

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
        <div>
          <div style={{fontSize:14,fontWeight:500}}>Simulador de cenários — {clienteNome}</div>
          <div style={{...s0,fontSize:12,marginTop:2}}>Diferenças estimadas · sem prescrição de conduta</div>
        </div>
        <button onClick={() => openBuilder()} style={{padding:"6px 16px",borderRadius:8,fontSize:13,fontWeight:500,background:"var(--color-background-info)",color:"var(--color-text-info)",border:"0.5px solid var(--color-border-info)",cursor:"pointer",flexShrink:0}}>+ Novo cenário</button>
      </div>
      <div style={C}>
        <div style={{fontSize:12,fontWeight:500,marginBottom:10}}>Cenário base</div>
        <div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
          <MetricCard label="Base mínima"   value={fmt(bT.bM)}/>
          <MetricCard label="IRRF Art. 6-A" value={fmt(bT.i6A)} danger={bT.i6A>0}/>
          <MetricCard label="Redutor 16-B"  value={fmt(bT.incV)} ok={bT.incV>0}/>
          <MetricCard label="Saldo DAA est."value={fmt(bT.sDF)} danger={bT.sDF>0} ok={bT.sDF<0}/>
        </div>
      </div>
      {cens.length === 0 && <div style={{...C,textAlign:"center",padding:28,background:"var(--color-background-secondary)"}}><div style={s0}>Nenhum cenário salvo. Crie para explorar o impacto fiscal estimado.</div></div>}
