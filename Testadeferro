/* ── SNAPSHOT / AUDITORIA ────────────────────── */
function criarSnapshot({ lans, pjData, consultor, tipo, nota }) {
  const m6A  = calcMotor6A(lans);
  const trib = calcTrib(lans, m6A, pjData);
  return {
    id:        "snap_" + Date.now(),
    ts:        new Date().toISOString(),
    consultor,
    versaoRegra: TRC.v,
    norma:       TRC.norm,
    tipo,   // "apresentacao" | "manual"
    nota:   nota || "",
    lansSnapshot:   JSON.parse(JSON.stringify(lans)),
    pjDataSnapshot: JSON.parse(JSON.stringify(pjData || {})),
    resultado: {
      bB:   trib.bB,   bM:   trib.bM,
      aliq: trib.aliq, tMB:  trib.tMB,
      incI: trib.incI, incII: trib.incII, incIII: trib.incIII,
      incV: trib.incV, i6A:  trib.i6A,
      r3:   trib.r3,   r4:   trib.r4,
      r5:   trib.r5,   sDF:  trib.sDF,
      pendencias: trib.pend.map(p => ({ nome: p.nome, m: p.m })),
      exclusoes:  trib.excl.map(e => ({ m: e.m, v: e.v })),
      numLancamentos: lans.length,
    },
  };
}

