/* ── INTELIGÊNCIA DA CARTEIRA ────────────────── */
function getRisco(cli) {
  if (!cli.lans?.length) return { nivel:"sem_dados", score:0, label:"Sem dados", cor:"#888780", aliq:0, sDF:0, bM:0, i6A:0, pend:0 };
  const t = fullCalc(cli.lans, cli.pjData||{});
  const score = t.aliq*100 + t.pend.length*5;
  const nivel = t.aliq >= 0.10 ? "critico" : t.aliq >= 0.05 ? "alto" : t.aliq > 0 ? "moderado" : "baixo";
  const labels = { critico:"Crítico",alto:"Alto",moderado:"Moderado",baixo:"Abaixo do limiar" };
  const cores  = { critico:"#E24B4A",alto:"#EF9F27",moderado:"#BA7517",baixo:"#1D9E75" };
  return { nivel, score, label:labels[nivel], cor:cores[nivel], aliq:t.aliq, sDF:t.sDF, bM:t.bM, i6A:t.i6A, pend:t.pend.length };
}

